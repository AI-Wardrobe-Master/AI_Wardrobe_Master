# 复制为 .env 后填写
# 该文件用于本地直接运行 backend（venv/conda）。
# 如果使用仓库根目录的 docker-compose.yml，compose 会直接注入容器环境变量。

POSTGRES_SERVER=localhost
POSTGRES_USER=wardrobe_user
POSTGRES_PASSWORD=wardrobe_pass
POSTGRES_DB=wardrobe_db
POSTGRES_PORT=5432

LOCAL_STORAGE_PATH=./storage
API_BASE_URL=http://localhost:8000
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Roboflow workflow classification
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_API_KEY=your-roboflow-api-key
ROBOFLOW_WORKSPACE_NAME=bcs-workspace-vo3qr
ROBOFLOW_WORKFLOW_ID=custom-workflow
ROBOFLOW_IMAGE_INPUT_NAME=image
ROBOFLOW_TIMEOUT_SECONDS=30

# DreamO Service
DREAMO_SERVICE_URL=http://localhost:9000
DREAMO_GENERATE_TIMEOUT_SECONDS=300
